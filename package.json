{
    "author": "Ivo Kalendarov <ivokalendar@icloud.com>",
    "name": "mern-setup",
    "displayName": "Mern Setup",
    "description": "Fullstack MERN setup with SSR and Vite (Not in use anymore)",
    "version": "1.0.0",
    "main": "index.js",
    "type": "module",
    "nodemonConfig": { 
        "ext": "js", 
        "ignore": ["*.test.ts", "db/*"], 
        "delay": "2" 
    },
    "scripts": {
        "vite": "vite",
        "vite-build": "vite build",
        "vite-start": "vite preview",
        "start": "npm run build && npm run preview",
        "dev-client": "npm run vite -- --host --open",

        "dev": "nodemon server",
        "build": "npm run build:client && npm run build:server",
        "build:client": "vite build --ssrManifest --outDir dist/client",
        "build:server": "vite build --ssr client/entry/entry-server.jsx --outDir dist/server",
        "preview": "cross-env NODE_ENV=production node server",
        "clean-deep": "rm -rf node_modules package-lock.json .vite_cache dist",
        "clean-install": "npm run clean-deep && npm install",
        "clean": "rm -rf .vite_cache dist",
        "clean-dev": "npm run clean && npm run dev",
        "clean-start": "npm run clean && npm run start"
    },
    "license": "ISC",
    "dependencies": {
        "axios": "1.13.6",
        "compression": "1.8.1",
        "dotenv": "17.3.1",
        "express": "5.2.1",
        "mongodb": "7.1.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-icons": "5.5.0",
        "react-router-dom": "7.13.1",
        "sirv": "3.0.2",
        "uuid": "13.0.0"
    },
    "devDependencies": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.1.4",
        "cross-env": "10.1.0",
        "nodemon": "3.1.14",
        "vite": "7.3.1"
    }
}
